# Spotify Developer Dashboard: https://developer.spotify.com/dashboard
# Create an app, then copy Client ID and Client Secret here.
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# Redirect URI - must match EXACTLY what you set in the Spotify Developer Dashboard.
# For local access: http://127.0.0.1:3000/api/auth/callback
# For LAN access:   http://YOUR_IP:3000/api/auth/callback
# NOTE: "localhost" does not work with Spotify. Use 127.0.0.1 or your machine's IP.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# Session encryption key (generate with: openssl rand -hex 32)
SESSION_SECRET=your_64_char_hex_here
